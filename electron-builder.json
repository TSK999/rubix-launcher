{
  "appId": "com.rubix.launcher",
  "productName": "RUBIX Launcher",
  "directories": {
    "output": "installer-release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "build/**/*",
    "package.json"
  ],
  "publish": [
    {
      "provider": "github",
      "owner": "TSK999",
      "repo": "rubix-launcher",
      "releaseType": "release"
    }
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      { "target": "nsis", "arch": ["x64"] }
    ],
    "artifactName": "RUBIX-Launcher-Setup-${version}.${ext}"
  },
  "mac": {
    "icon": "build/icon.png"
  },
  "linux": {
    "icon": "build/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "RUBIX Launcher"
  }
}
